{
  "name": "dart-scorer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:clean": "rm -rf .next && next dev --webpack",
    "clean": "rm -rf .next",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "generate-tts": "node --env-file=.env.local scripts/generate-tts-phrases.mjs",
    "generate-score-clips": "node scripts/generate-score-clips.mjs",
    "seed-score-clips": "node --env-file=.env.local scripts/seed-score-clips.mjs",
    "seed-voice-clips": "tsx --env-file=.env.local scripts/seed-all-voice-clips.ts",
    "seed-bot-voice-clips": "tsx --env-file=.env.local scripts/seed-bot-voice-clips.ts",
    "seed-x01-voice-clips": "tsx --env-file=.env.local scripts/seed-x01-voice-clips.ts",
    "generate-cricket-closed-clips": "node scripts/generate-cricket-closed-clips.mjs",
    "generate-game-shot-clips": "node scripts/generate-game-shot-clips.mjs",
    "generate-checkout-clips": "node scripts/generate-checkout-clips.mjs",
    "generate-hit-miss-clips": "node scripts/generate-hit-miss-clips.mjs",
    "generate-golf-clips": "node scripts/generate-golf-clips.mjs",
    "generate-baseball-clips": "node scripts/generate-baseball-clips.mjs",
    "generate-killer-clips": "node scripts/generate-killer-clips.mjs",
    "generate-shanghai-clips": "node scripts/generate-shanghai-clips.mjs",
    "generate-bobs-27-clips": "node scripts/generate-bobs-27-clips.mjs",
    "generate-halve-it-clips": "node scripts/generate-halve-it-clips.mjs",
    "generate-checkout-121-clips": "node scripts/generate-checkout-121-clips.mjs",
    "generate-tic-tac-toe-clips": "node scripts/generate-tic-tac-toe-clips.mjs",
    "generate-player-turn-clips": "node scripts/generate-player-turn-clips.mjs",
    "generate-game-on-clips": "node scripts/generate-game-on-clips.mjs",
    "preview-score-voices": "node scripts/preview-score-voices.mjs",
    "sync-tts-env": "node scripts/sync-tts-env.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "framer-motion": "^12.42.2",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
