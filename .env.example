# Supabase (optional — enables cloud palettes, profiles, and match history)
# Create a project at https://supabase.com, then paste your project URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Setup:
# 1. Copy this file to .env.local and fill in the values above.
# 2. Run supabase/migrations/20260705183000_initial_schema.sql in the Supabase SQL editor
#    (or use the Supabase CLI: supabase link && supabase db push).
