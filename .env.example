# Supabase (optional — enables auth, cloud palettes, profiles, and match history)
# Create a project at https://supabase.com, then paste your project URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — required for uploading generated voice clips to Supabase Storage (Vercel production)
SUPABASE_SERVICE_ROLE_KEY=

# Setup:
# 1. Copy this file to .env.local and fill in the values above.
# 2. Run migrations in order in the Supabase SQL editor
#    (or use the Supabase CLI: supabase link && supabase db push):
#    - supabase/migrations/20260705183000_initial_schema.sql
#    - supabase/migrations/20260705210000_player_stats_and_avatars.sql
#    - supabase/migrations/20260708190000_voice_clips_storage.sql
# 3. In Supabase Dashboard → Authentication → URL Configuration, add:
#    - Site URL: http://localhost:3000 (or your production origin)
#    - Redirect URLs: http://localhost:3000/auth/callback
#      (and https://your-domain/auth/callback for production)
# 4. Email/password is enabled by default. Toggle "Confirm email" under
#    Authentication → Providers → Email depending on whether you want
#    confirm-link signup or immediate sign-in.

# Voice announcements (Sadachbia and other Gemini voices)
# Required: create a key at https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=
# Gemini TTS model (default: gemini-2.5-pro-preview-tts)
GOOGLE_GEMINI_TTS_MODEL=
# Voice name (default: Sadachbia)
GOOGLE_CLOUD_TTS_VOICE=
# Delivery style — quote multi-word values so dotenv does not truncate them
GOOGLE_CLOUD_TTS_PROMPT=

# Optional — only needed for classic Neural/Wavenet voices (not Sadachbia)
GOOGLE_CLOUD_TTS_API_KEY=
GOOGLE_CLOUD_TTS_SPEAKING_RATE=
GOOGLE_CLOUD_TTS_PITCH=

# Player turn + Game On voice clips (Daniel-style, automatic per player name)
# macOS dev: Next.js uses built-in `say` + Daniel (English UK) — no extra setup.
# Vercel production:
#   1. Run the voice worker with Docker (services/voice-worker — see README there)
#   2. Set VOICE_SYNTHESIS_URL to the worker URL (e.g. http://your-server:8787)
#   3. Set SUPABASE_SERVICE_ROLE_KEY so clips upload to the voice-clips bucket (CDN cache)
VOICE_SYNTHESIS_URL=
VOICE_SYNTHESIS_TOKEN=
# Optional — if Next.js runs on Linux with Piper directly (not Vercel)
PIPER_BIN=piper
PIPER_MODEL_PATH=
LOCAL_SAY_TURN_VOICE=Daniel (English (UK))
LOCAL_SAY_TURN_RATE=168
LOCAL_SAY_CACHE_DIR=
